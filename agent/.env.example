# NeuroVault Agent Configuration
# Copy this to .env and fill in your values

# === REQUIRED ===

# Google Gemini API Key — https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key

# Polkadot Hub RPC endpoint
RPC_URL=https://eth-rpc-testnet.polkadot.io/

# NeuroVault contract address
CONTRACT_ADDRESS=0x195FAc0dc3AFaD9AA7dE057B786b8613742d3D8e

# Agent wallet private key (submits proposals on-chain)
AGENT_PRIVATE_KEY=0x...

# === CYCLE CONFIG ===

# Cron expression (default: every 30 minutes)
CYCLE_INTERVAL=*/30 * * * *

# Minimum AI confidence threshold (0-1)
MIN_CONFIDENCE=0.50

# Cooldown between cycles (ms)
CYCLE_COOLDOWN_MS=60000

# === GOVERNANCE GUARDRAILS ===

# Max USD value per proposal
SPENDING_LIMIT_USD=50000

# Comma-separated approved target addresses
APPROVED_TARGETS=0x23CcE8797707c7b2Dd1354FCF4ef28256f98C00a,0x34b179eCC554DE9bdBC9736E5E3E804e8318D8f3,0x195FAc0dc3AFaD9AA7dE057B786b8613742d3D8e

# === LIT PROTOCOL (optional) ===

# Enable Lit Protocol key encryption
ENABLE_LIT=true

# === ENS REGISTRY (optional) ===

ENS_ADDRESS=0x3721472089bFe55c1E761c4Bb1776a731eca9817

# === IPFS / PINATA ===

PINATA_API_KEY=your_pinata_api_key
PINATA_API_SECRET=your_pinata_api_secret
PINATA_JWT=your_pinata_jwt_token

# === OPTIONAL ===

# External yield data endpoint
BIFROST_APY_URL=

# Server port
PORT=3001
