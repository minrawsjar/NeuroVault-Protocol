# Claude API Key - Get from https://console.anthropic.com/
CLAUDE_API_KEY=your_claude_api_key_here

# RPC URL for Polkadot Hub (or any EVM chain)
RPC_URL=https://rpc.polkadot.io

# Smart Contract Address
CONTRACT_ADDRESS=0x...

# Agent Private Key (optional - for submitting proposals on-chain)
# If not provided, agent will only simulate proposals
AGENT_PRIVATE_KEY=0x...

# Cycle interval (cron expression)
# Default: every 30 minutes
CYCLE_INTERVAL=*/30 * * * *

# Minimum confidence threshold (0-100)
MIN_CONFIDENCE=70

# API Server Port
PORT=3001
